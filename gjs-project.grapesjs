e":"text","classes":["cls-1zf6uz"],"components":[{"type":"textnode","content":"Digital key"}]}]},{"type":"label","classes":["cls-4iatrx"],"components":[{"type":"radio","void":true,"attributes":{"type":"radio","name":"edition"}},{"tagName":"span","type":"text","classes":["cls-3cq511"],"components":[{"type":"textnode","content":"Physical disc"}]}]}]},{"classes":["cls-bsaqab"],"components":[{"type":"button","classes":["gjs-t-button","cls-wf9xyu"],"attributes":{"type":"button"},"components":[{"type":"contentEditable","components":[{"type":"textnode","content":"Add to Cart"}]}]},{"type":"button","classes":["cls-uezn9h"],"attributes":{"type":"button"},"components":[{"type":"contentEditable","components":[{"type":"textnode","content":"Add to Wishlist"}]}]}]},{"classes":["cls-ogu4ux"]},{"classes":["cls-0kon4g"],"components":[{"tagName":"span","type":"text","classes":["cls-ih36t8"],"components":[{"type":"textnode","content":"System Requirements (min):"}]},{"tagName":"ul","classes":["cls-z1tzr7"],"components":[{"tagName":"li","type":"text","components":[{"type":"textnode","content":"CPU: Intel i5 or AMD FX"}]},{"tagName":"li","type":"text","components":[{"type":"textnode","content":"GPU: GTX 960 / RX 470"}]},{"tagName":"li","type":"text","components":[{"type":"textnode","content":"RAM: 8 GB"}]},{"tagName":"li","type":"text","components":[{"type":"textnode","content":"Storage: 20 GB"}]}]}]}]}]}]}]},{"type":"script","components":[{"type":"textnode","content":"\n(function(){\n  const track = document.getElementById('heroTrack');\n  const dots = Array.from(document.querySelectorAll('.carousel-dot'));\n  const prev = document.getElementById('heroPrev');\n  const next = document.getElementById('heroNext');\n  let index = 0, total = dots.length;\n  function update(i){\n    index = (i + total) % total;\n    track.style.transform = 'translateX(' + (-100 * index) + '%)';\n    dots.forEach((d,di)=>d.classList.toggle('active', di===index));\n  }\n  prev && prev.addEventListener('click', ()=>update(index-1));\n  next && next.addEventListener('click', ()=>update(index+1));\n  dots.forEach(d=>d.addEventListener('click', ()=>update(parseInt(d.dataset.dot,10))));\n  let auto = setInterval(()=>update(index+1), 6000);\n  ['mouseenter','touchstart'].forEach(ev=>track.addEventListener(ev, ()=>clearInterval(auto)));\n})();\n(function(){\n  const btn = document.getElementById('miniCartBtn');\n  const drawer = document.getElementById('miniCart');\n  const overlay = document.getElementById('miniCartOverlay');\n  const close = document.getElementById('miniCartClose');\n  function open(){drawer.classList.add('open'); overlay.classList.add('show');}\n  function shut(){drawer.classList.remove('open'); overlay.classList.remove('show');}\n  btn && btn.addEventListener('click', open);\n  close && close.addEventListener('click', shut);\n  overlay && overlay.addEventListener('click', shut);\n})();\n(function(){\n  // Horizontal scroll controls\n  const left = document.querySelector('[data-scroll-left=\"nr\"]');\n  const right = document.querySelector('[data-scroll-right=\"nr\"]');\n  const row = document.getElementById('nrTrack');\n  left && left.addEventListener('click', ()=>row.scrollBy({left:-320, behavior:'smooth'}));\n  right && right.addEventListener('click', ()=>row.scrollBy({left:320, behavior:'smooth'}));\n})();\n(function(){\n  // Example: open product modal when clicking the first New Release\n  const card = document.querySelector('[data-gjs-name=\"Game Card\"] a');\n  const modal = document.getElementById('productModal');\n  const close = document.getElementById('productModalClose');\n  if(card && modal){\n    card.addEventListener('click', (e)=>{ e.preventDefault(); modal.classList.add('show'); modal.setAttribute('aria-hidden','false'); });\n  }\n  close && close.addEventListener('click', ()=>{ modal.classList.remove('show'); modal.setAttribute('aria-hidden','true'); });\n  modal && modal.addEventListener('click', (e)=>{ if(e.target===modal){ modal.classList.remove('show'); modal.setAttribute('aria-hidden','true'); }});\n})();\n"}]}],"doctype":"<!DOCTYPE html>","head":{"type":"head","components":[{"tagName":"meta","void":true,"attributes":{"charset":"utf-8"}},{"tagName":"meta","void":true,"attributes":{"name":"viewport","content":"width=device-width, initial-scale=1"}},{"tagName":"title","type":"text","components":[{"type":"textnode","content":"GameStore Home"}]}]},"docEl":{"tagName":"html","attributes":{"lang":"en"}}},"id":"AOtK65l0kp9bNyrn","minHeight":"500px"}],"id":"zobx5RK2wfIuxSTN"}],"symbols":[],"custom":{"projectType":"web","id":""}}